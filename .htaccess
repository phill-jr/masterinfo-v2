# ========================================
# MasterInfo - Regras de Seguranca Apache
# ========================================

# Bloquear acesso direto a arquivos sensiveis
<FilesMatch "^(config\.php|credentials\.php|credentials\.example\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear backups e arquivos temporarios
<FilesMatch "\.(bak|log|sql|sh|env|swp|orig)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear markdowns de documentacao interna
<FilesMatch "^(CLAUDE|MAPEAMENTO|HANDOFF-BITRIX|INTEGRACAO-MARINA-BOLETOS|COMO-EDITAR|SECURITY-AUDIT-CODE|SECURITY-AUDIT-INFRA)\.md$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear scripts Python (gerar_subpaginas.py etc)
<FilesMatch "\.py$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear config.json.bak
<Files "config.json.bak">
    Order allow,deny
    Deny from all
</Files>

# Canonical host: forca NON-www. Pos-migracao o www servia 200 (conteudo duplicado)
# e causava canibalizacao www/non-www no Google. 301 www.* -> dominio sem www. (18/06/2026)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# Bloquear pastas sensiveis
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear secrets/
    RewriteRule ^secrets/.*$ - [F,L]

    # Bloquear auth/ exceto endpoints permitidos
    RewriteRule ^auth/(?!login\.php|logout\.php|check\.php).*$ - [F,L]
</IfModule>

# Pagina 404 personalizada (branded) em vez do default do Apache
ErrorDocument 404 /404.html

# Impedir listagem de diretorios
Options -Indexes

# Home padrao = tema claro (index-light). Producao cutover 15/06/2026.
DirectoryIndex index-light.html index.html index.php

# Forcar HTTPS em producao (descomentar quando tiver certificado SSL)
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>

# ========================================
# 301 Redirects - migracao WordPress -> v2 (17/06/2026)
# URLs do WP antigo ainda indexadas no Google davam 404/orfas (achado via
# auditoria GSC awesome-gsc). 301 preserva o SEO/link equity. RedirectMatch
# (mod_alias) com ^...$ ancorado evita prefix-bleed (ex.: /assine != /assine-ja).
# Destinos sao paginas v2 indexaveis (nao mandar equity p/ checkout noindex).
# ========================================
<IfModule mod_alias.c>
    RedirectMatch 301 ^/planos-residenciais/?$   /familia/
    RedirectMatch 301 ^/planos-empresariais/?$   /
    RedirectMatch 301 ^/fale-conosco/?$          /contato/
    RedirectMatch 301 ^/trabalheconosco/?$       /contato/
    RedirectMatch 301 ^/formulario-bitrix/?$     /contato/
    RedirectMatch 301 ^/contratos/?$             /termos/
    RedirectMatch 301 ^/assine/?$                /
    RedirectMatch 301 ^/assine-ja/?$             /
    RedirectMatch 301 ^/cadastro/?$              /
    RedirectMatch 301 ^/our-services/?$          /
    RedirectMatch 301 ^/combos/?$                /
    RedirectMatch 301 ^/pacotes-telefonia/?$     /
    # Lote 2 (18/06): mais órfãs do WP achadas via canibalização no GSC
    RedirectMatch 301 ^/politica-de-privacidade/?$  /privacidade/
    RedirectMatch 301 ^/politica-de-cookies/?$      /privacidade/
    RedirectMatch 301 ^/termos-de-uso/?$            /termos/
    RedirectMatch 301 ^/sobre/?$                    /
    RedirectMatch 301 ^/sobre-nos/?$                /
    RedirectMatch 301 ^/quem-somos/?$               /
    RedirectMatch 301 ^/planos/?$                   /
</IfModule>

# ========================================
# Performance: headers de seguranca, cache e WebP (20/06/2026)
# Servido pelo Apache (modo nginx->apache proxy); .htaccess escopado a este dominio.
# Resolve sitechecker: security headers, cache lifetimes, next-gen images.
# ========================================

# --- Headers de seguranca ---
# Dentro de <FilesMatch>: no modo nginx->apache proxy (X-Accel) so headers em escopo
# de ARQUIVO atravessam pro cliente (header global de diretorio fica preso no Apache —
# confirmado: cache via FilesMatch/ExpiresByType passou, Header global nao). Cobre as
# paginas (html/php) — onde X-Frame-Options/nosniff/etc. importam.
<IfModule mod_headers.c>
    <FilesMatch "(\.(html?|php)$|^[^.]*$)">
        Header set X-Frame-Options "SAMEORIGIN"
        Header set X-Content-Type-Options "nosniff"
        Header set Referrer-Policy "strict-origin-when-cross-origin"
        Header set Strict-Transport-Security "max-age=31536000"
    </FilesMatch>
</IfModule>

# --- Cache de estaticos ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType image/jpeg "access plus 14 days"
    ExpiresByType image/png "access plus 14 days"
    ExpiresByType image/webp "access plus 14 days"
    ExpiresByType image/svg+xml "access plus 14 days"
    ExpiresByType image/gif "access plus 14 days"
    ExpiresByType image/x-icon "access plus 14 days"
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>
</IfModule>

# --- WebP transparente: serve x.jpg.webp se o browser aceitar E o arquivo existir ---
# (os .webp ja estao no servidor ao lado de cada imagem). Fallback automatico pro original.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_FILENAME}\.webp -f
    RewriteRule (.+)\.(jpe?g|png)$ $1.$2.webp [T=image/webp,L]
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(jpe?g|png)$">
        Header append Vary Accept
    </FilesMatch>
</IfModule>
